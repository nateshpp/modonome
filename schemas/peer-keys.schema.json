{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://modonome.com/schemas/peer-keys.schema.json",
  "title": "Modonome peer key allowlist",
  "description": "Committed, CODEOWNERS-gated trust root for knowledge packet signatures (ADR-017). Off by default.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "keys"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "keys": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["alias", "ed25519_pubkey_b64", "added_by", "added_at", "status"],
        "properties": {
          "alias": { "type": "string", "minLength": 1 },
          "ed25519_pubkey_b64": { "type": "string", "minLength": 1 },
          "added_by": { "type": "string", "minLength": 1 },
          "added_at": { "type": "string" },
          "status": { "type": "string", "enum": ["active", "revoked"] },
          "not_before": { "type": "string" },
          "not_after": { "type": "string" }
        }
      }
    }
  }
}
