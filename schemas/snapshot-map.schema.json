{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://modonome.com/schemas/snapshot-map.schema.json",
  "title": "Modonome snapshot map (Tier 1)",
  "description": "Compressed repository map for LLM context: modules, public API, edges, attention.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "merkle_root", "modules", "api", "edges", "attention"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "merkle_root": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "dictionary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "paths": { "type": "object" },
        "symbols": { "type": "object" }
      }
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "path", "hash"],
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "purpose": { "type": "string" },
          "hash": { "type": "string" }
        }
      }
    },
    "api": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["anchor", "path_id", "kind", "name", "signature", "line"],
        "properties": {
          "anchor": { "type": "string" },
          "path_id": { "type": "string" },
          "kind": { "type": "string" },
          "name": { "type": "string" },
          "signature": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "doc": { "type": "string" }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" }
        }
      }
    },
    "attention": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path_id"],
        "properties": {
          "path_id": { "type": "string" },
          "centrality": { "type": "integer", "minimum": 0 },
          "pagerank": { "type": "number", "minimum": 0 }
        }
      }
    },
    "token_estimate": { "type": "integer", "minimum": 0 },
    "token_budget": { "type": "integer", "minimum": 0 },
    "truncated": { "type": "boolean" }
  }
}
