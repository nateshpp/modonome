{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://modonome.com/schemas/snapshot-signature.schema.json",
  "title": "Modonome snapshot signature (Tier 0)",
  "description": "Small repository fingerprint. If merkle_root is unchanged, the repo is unchanged.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "merkle_root", "snapshot_version", "generated_at"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "preamble": { "type": "string" },
    "generated_for": { "type": "string" },
    "generated_at": { "type": "string" },
    "merkle_root": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "stack": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "pm": { "type": "string" }
      }
    },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "files": { "type": "integer", "minimum": 0 },
        "bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "language_mix": { "type": "object" },
    "entrypoints": { "type": "array", "items": { "type": "string" } },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "test": { "type": "string" },
        "build": { "type": "string" },
        "lint": { "type": "string" }
      }
    },
    "instructions": { "type": "array", "items": { "type": "string" } },
    "protected_paths": { "type": "array", "items": { "type": "string" } },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "armed": { "type": "boolean" },
        "autonomy_enabled": { "type": "boolean" },
        "dry_run": { "type": "boolean" }
      }
    },
    "snapshot_version": { "type": "integer", "minimum": 1 },
    "tier_hashes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "map": { "type": "string" },
        "map_md": { "type": "string" }
      }
    }
  }
}
