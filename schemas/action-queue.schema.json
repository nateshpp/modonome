{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://modonome.com/schemas/action-queue.schema.json",
  "title": "Modonome action queue record",
  "description": "One queued execution-target-routed action. Mirrors the ADR-007 lease pattern: a claimed record carries lease_expires_at, and a stale lease reverts to queued.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "target", "role", "model", "transport", "state", "created_at"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "minLength": 1 },
    "target": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "transport": { "type": "string", "minLength": 1 },
    "state": { "type": "string", "enum": ["queued", "claimed", "done", "failed"] },
    "lease_expires_at": { "type": "string" },
    "owner": { "type": "string" },
    "created_at": { "type": "string", "minLength": 1 },
    "result": { "type": "object" },
    "payload": { "type": "object" }
  }
}
