{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://modonome.com/schemas/adoption-map.schema.json",
  "title": "Modonome adoption map",
  "description": "Spec of record: prompts/modules/adoption.md.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source_of_truth", "system_of_change", "gates", "merge_authority"],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "source_of_truth": { "type": "string", "minLength": 1 },
    "decision_queue": { "type": "string" },
    "learning_queue": { "type": "string" },
    "network_state": { "type": "string" },
    "system_of_change": {
      "type": "string",
      "enum": ["git", "monorepo", "service_catalog", "mirror", "mainframe", "packaged_platform", "low_code", "infrastructure"]
    },
    "protected_paths": { "type": "array", "items": { "type": "string" } },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "blocking"],
        "properties": {
          "name": { "type": "string" },
          "command": { "type": "string", "minLength": 1 },
          "blocking": { "type": "boolean" }
        }
      }
    },
    "merge_authority": { "type": "string", "enum": ["human", "bot", "disabled"] },
    "ui_surface": { "type": "string" },
    "stack_fingerprint": { "type": "string" }
  }
}
