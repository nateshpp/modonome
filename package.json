{
  "name": "modonome",
  "version": "0.1.0-alpha",
  "description": "HARDENED - Governed autonomy for any repo. An off-by-default autonomy loop that adopts your repo's rules, proposes small reviewable changes, and gates them in CI so weakened tests cannot merge.",
  "type": "module",
  "bin": {
    "modonome": "bin/modonome.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build:prompt": "node scripts/build-prompt.mjs --write",
    "check:prompt": "node scripts/build-prompt.mjs --check",
    "check:drift": "node scripts/check-drift.mjs",
    "check:style": "node scripts/check-style.mjs .",
    "check:md-governance": "node scripts/check-md-governance.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-exclude='tests/**' --test-coverage-exclude='agentproof/**' --test-coverage-lines=80 --test-coverage-branches=66 --test-coverage-functions=80 tests/*.test.mjs",
    "govbench": "node agentproof/runner.mjs",
    "preflight": "node scripts/preflight-embedding.mjs",
    "check:control-panel": "node scripts/check-control-panel-coverage.mjs && node scripts/check-control-panel-coherence.mjs",
    "verify": "npm run check:drift && npm run check:style && node scripts/check-repo-hygiene.mjs && node scripts/check-md-governance.mjs && node scripts/check-self-application.mjs && node scripts/check-learning-traceability.mjs && node scripts/check-promotion-readiness.mjs && node scripts/check-work-items.mjs && node scripts/check-checker-engagement.mjs && npm run check:control-panel && npm test && npm run agentproof && npm run evidence",
    "audit:learnings": "node scripts/audit-learnings.mjs",
    "evidence": "node scripts/build-release-evidence.mjs",
    "check:evidence": "node scripts/build-release-evidence.mjs --check",
    "dry-run": "node scripts/dry-run-sweep.mjs",
    "scaffold": "node scripts/scaffold.mjs",
    "agentproof": "node agentproof/runner.mjs",
    "report": "node scripts/report.mjs",
    "demo:agent": "node scripts/agent/run-cycle.mjs",
    "prepare": "node scripts/install-hooks.mjs",
    "release": "node scripts/release.mjs",
    "preversion": "npm run verify",
    "prepublishOnly": "node --test tests/*.test.mjs"
  },
  "files": [
    "bin",
    "prompts",
    "templates",
    "schemas",
    "scripts",
    "docs",
    "agentproof",
    "tests"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/enumind/modonome.git"
  },
  "homepage": "https://modonome.com",
  "keywords": [
    "autonomous",
    "agent",
    "ci",
    "governance",
    "code-review",
    "modernization",
    "tech-debt",
    "ai-safety",
    "agentic",
    "autonomy",
    "ratchet",
    "agentproof"
  ]
}
